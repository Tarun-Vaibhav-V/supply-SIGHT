# SupplySight — Environment Configuration
# Copy this file to .env and update with your credentials

SUPPLYSIGHT_DB_USER=postgres
SUPPLYSIGHT_DB_PASS=YOUR_PASSWORD_HERE
SUPPLYSIGHT_DB_HOST=localhost
SUPPLYSIGHT_DB_PORT=5432
SUPPLYSIGHT_DB_NAME=supplysight

# Auth
JWT_SECRET_KEY=change-me-to-a-random-256-bit-secret
ADMIN_INVITE_CODE=SUPPLYSIGHT_ADMIN_2026

# Google OAuth (optional — add when ready)
# GOOGLE_CLIENT_ID=your-google-client-id
# GOOGLE_CLIENT_SECRET=your-google-client-secret

# Gemini AI (optional — add when ready)
# GEMINI_API_KEY=your-gemini-api-key
